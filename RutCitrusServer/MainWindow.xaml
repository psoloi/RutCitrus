<ui:FluentWindow
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RutCitrusServer"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        x:Class="RutCitrusServer.MainWindow"
        mc:Ignorable="d"
        Title="RutCitrusServer" Height="650" Width="950"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="RutCitrusServer" ShowMinimize="True" ShowMaximize="True" ShowClose="True"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ui:NavigationView Grid.Column="0" x:Name="NavigationView" PaneDisplayMode="Left" IsPaneToggleVisible="False" OpenPaneLength="200">
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem Content="主页" Icon="{ui:SymbolIcon Home24}" Click="HomeButton_Click"/>
                    <ui:NavigationViewItem Content="功能" Icon="{ui:SymbolIcon Wrench24}" Click="FeatureButton_Click"/>
                    <ui:NavigationViewItem Content="扩展" Icon="{ui:SymbolIcon PuzzlePiece24}" Click="ExtensionButton_Click"/>
                    <ui:NavigationViewItem Content="设置" Icon="{ui:SymbolIcon Settings24}" Click="SettingButton_Click"/>
                </ui:NavigationView.MenuItems>
                <ui:NavigationView.FooterMenuItems>
                    <ui:NavigationViewItem Content="添加服务器" Icon="{ui:SymbolIcon Add24}" Click="AddServerButton_Click"/>
                </ui:NavigationView.FooterMenuItems>
            </ui:NavigationView>

            <Grid Grid.Column="1" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ui:Card Grid.Row="0" Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <ui:TextBlock Text="状态: " FontWeight="SemiBold"/>
                        <ui:TextBlock x:Name="StatusText" Text="未连接"/>
                    </StackPanel>
                </ui:Card>

                <Grid Grid.Row="1">
                    <ScrollViewer x:Name="HomePanel" Visibility="Visible" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <ui:TextBlock Text="主页" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            
                            <ui:CardExpander Margin="0,0,0,16" Header="服务器列表" Icon="{ui:SymbolIcon Server24}">
                                <StackPanel>
                                    <ItemsControl x:Name="ServerItemsControl" ItemsSource="{Binding Servers}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ui:Card Margin="0,4" Padding="12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <ui:TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                                            <ui:TextBlock Text="{Binding DisplayEndpoint}" Foreground="Gray" FontSize="12"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                            <ui:Button Content="{Binding ButtonText}" 
                                                                       IsEnabled="{Binding CanConnect}"
                                                                       Margin="0,0,4,0" 
                                                                       Click="ConnectServerButton_Click" 
                                                                       Tag="{Binding}" 
                                                                       Appearance="{Binding ButtonAppearance}"/>
                                                            <ui:Button Content="删除" Click="DeleteServerButton_Click" Tag="{Binding}" Appearance="Danger"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </ui:Card>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    
                                    <ui:TextBlock x:Name="EmptyServerText" Text="暂无服务器，请点击左下角添加" 
                                                  Foreground="Gray" HorizontalAlignment="Center" Margin="0,16"/>
                                </StackPanel>
                            </ui:CardExpander>

                            <ui:CardExpander Header="日志" Icon="{ui:SymbolIcon DocumentText24}">
                                <ui:TextBox x:Name="LogTextBox" Height="150" IsReadOnly="True" 
                                            VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                                            AcceptsReturn="True" Margin="8"/>
                            </ui:CardExpander>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="FeaturePanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <ui:TextBlock Text="功能" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="ExtensionPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Grid.Column="0" Text="扩展管理" FontSize="20" FontWeight="SemiBold"/>
                                <ui:Button Grid.Column="1" Content="刷新" Icon="{ui:SymbolIcon ArrowSync24}" Click="RefreshExtensionsButton_Click"/>
                            </Grid>
                            
                            <ui:Card Margin="0,0,0,8" Padding="12">
                                <ui:TextBlock Text="显示已连接服务器上 RtCli 加载的扩展，可以在此卸载扩展。" Foreground="Gray" TextWrapping="Wrap"/>
                            </ui:Card>
                            
                            <ui:TextBlock x:Name="ExtensionNotConnectedText" Text="请先连接到服务器" 
                                          Foreground="Orange" HorizontalAlignment="Center" Margin="0,16" Visibility="Collapsed"/>
                            
                            <ItemsControl x:Name="ExtensionItemsControl" ItemsSource="{Binding Extensions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:Card Margin="0,4" Padding="12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                                        <ui:TextBlock Text=" v" Foreground="Gray" FontSize="12" VerticalAlignment="Center"/>
                                                        <ui:TextBlock Text="{Binding Version}" Foreground="Gray" FontSize="12" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <ui:TextBlock Text="{Binding Description}" Foreground="Gray" FontSize="12" TextWrapping="Wrap" MaxHeight="40"/>
                                                    <ui:TextBlock Text="{Binding LoadTime}" Foreground="DarkGray" FontSize="10"/>
                                                </StackPanel>
                                                <ui:Button Grid.Column="1" Content="卸载" Click="UnloadExtensionButton_Click" 
                                                           Tag="{Binding Key}" Appearance="Danger"/>
                                            </Grid>
                                        </ui:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <ui:TextBlock x:Name="EmptyExtensionText" Text="暂无已加载的扩展" 
                                          Foreground="Gray" HorizontalAlignment="Center" Margin="0,16"/>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="SettingPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <ui:TextBlock Text="设置" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            
                            <ui:CardExpander Header="连接设置" Icon="{ui:SymbolIcon PlugConnected24}" IsExpanded="True">
                                <StackPanel Margin="8">
                                    <ui:TextBlock Text="暂无可配置项" Foreground="Gray"/>
                                </StackPanel>
                            </ui:CardExpander>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
